# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-api-key

# ─── Redis (for BullMQ job queue) ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Must match the JWT secret in your Supabase project settings
JWT_SECRET=your-supabase-jwt-secret

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (leave empty to allow all in dev)
CORS_ORIGIN=http://localhost:8081

# ─── Expo Push (optional, for sending notifications) ──────────────────────────
# No key needed — Expo handles auth via the push token from the device
