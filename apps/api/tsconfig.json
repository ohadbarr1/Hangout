{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022", "ES2022.Error"],
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@hangout/shared": ["../../packages/shared/src/types"]
    }
  },
  "include": ["src/**/*", "../../packages/shared/src/**/*"],
  "ts-node": {
    "transpileOnly": true
  },
  "exclude": ["node_modules", "dist"]
}
